{
  "name": "@pramen/react",
  "version": "0.0.1",
  "description": "React hooks for a pramen backend — useLiveQuery (reactive) + useMutation.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": "./src/index.ts"
  },
  "types": "./src/index.ts",
  "files": ["dist", "src"],
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json"
  },
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": { "types": "./dist/index.d.ts", "import": "./dist/index.js" }
    }
  },
  "dependencies": {
    "@pramen/client": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=18"
  }
}
