{
  "name": "@pramen/server",
  "version": "0.1.0",
  "description": "pramen server runtime — schema, ACL, ORM, live queries, files, and the createPramen(app) factory for Cloudflare Workers + Durable Objects.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": "./src/index.ts",
    "./worker": "./src/worker-entry.ts"
  },
  "types": "./src/index.ts",
  "files": ["dist", "src"],
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json"
  },
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": { "types": "./dist/index.d.ts", "import": "./dist/index.js" },
      "./worker": { "types": "./dist/worker-entry.d.ts", "import": "./dist/worker-entry.js" }
    }
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250101.0"
  }
}
